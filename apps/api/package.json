{
  "name": "@prodigy/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:debug": "nest start --debug --watch",
    "migration:run": "npx ts-node -r tsconfig-paths/register --project tsconfig.json ./node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "migration:revert": "npx ts-node -r tsconfig-paths/register --project tsconfig.json ./node_modules/typeorm/cli.js migration:revert -d src/database/data-source.ts",
    "migration:create": "npx typeorm migration:create"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.23",
    "@nestjs/platform-express": "^11.1.23",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "mysql2": "^3.22.3",
    "nestjs-pino": "^4.6.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
