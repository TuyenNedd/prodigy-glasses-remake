# ===========================================
# Prodigy Glasses Remake — Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# --- App ---
PORT=3001
NODE_ENV=development

# --- Database (MySQL 8) ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=prodigy
DB_PASSWORD=prodigy_secret
DB_DATABASE=prodigy_glasses

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- JWT (change these in production!) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# --- PayPal Sandbox ---
PAYPAL_CLIENT_ID=placeholder
PAYPAL_CLIENT_SECRET=placeholder
PAYPAL_WEBHOOK_ID=placeholder
USD_VND_RATE=24000

# --- Email (Mailhog in dev) ---
SMTP_HOST=localhost
SMTP_PORT=1025

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
